# Pear Media Configuration
# Add your API keys here

# OpenAI API (for text enhancement and image analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face API (for image generation via Stable Diffusion)
HUGGING_FACE_API_KEY=your_huggingface_api_key_here

# Stability AI API (optional, for direct Stability API calls)
STABILITY_API_KEY=your_stability_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development
